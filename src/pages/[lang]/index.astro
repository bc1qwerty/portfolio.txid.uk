---
import Base from '../../layouts/Base.astro';
import Header from '@txid/ui/components/Header.astro';
import Footer from '@txid/ui/components/Footer.astro';
import PortfolioSummary from '../../components/PortfolioSummary.astro';
import AddressForm from '../../components/AddressForm.astro';
import DonutChart from '../../components/DonutChart.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

const titles: Record<string, string> = {
  ko: 'Bitcoin Multi-Address Portfolio Tracker | txid.uk',
  en: 'Bitcoin Multi-Address Portfolio Tracker | txid.uk',
  ja: 'Bitcoin マルチアドレス ポートフォリオトラッカー | txid.uk',
};

const descriptions: Record<string, string> = {
  ko: '여러 비트코인 주소의 잔액을 한 화면에서 확인. 모든 데이터는 로컬에만 저장, 외부 전송 없음.',
  en: 'Track multiple Bitcoin address balances in one view. All data stored locally, no server transmission.',
  ja: '複数のビットコインアドレスの残高を一画面で確認。全データはローカルに保存、外部送信なし。',
};

const i18n: Record<string, Record<string, string>> = {
  heroSub: { ko: '여러 주소의 잔액을 한눈에 — 로컬 저장, 서버 전송 없음', en: 'Track multiple address balances at a glance — stored locally, no server', ja: '複数アドレスの残高を一覧 — ローカル保存、サーバー送信なし' },
  learnMore: { ko: '더 알아보기', en: 'Learn more', ja: 'もっと学ぶ' },
  walletChip: { ko: '지갑 주소란', en: 'Wallet Addresses', ja: 'ウォレットアドレス' },
  utxoChip: { ko: 'UTXO 모델', en: 'UTXO Model', ja: 'UTXOモデル' },
  addrPlaceholder: { ko: 'Bitcoin 주소 추가 (bc1, 1, 3...)', en: 'Add Bitcoin address (bc1, 1, 3...)', ja: 'Bitcoinアドレス追加 (bc1, 1, 3...)' },
  labelPlaceholder: { ko: '이름 (선택)', en: 'Label (optional)', ja: 'ラベル (任意)' },
  addBtn: { ko: '추가', en: 'Add', ja: '追加' },
  totalBtc: { ko: '총 BTC', en: 'Total BTC', ja: '合計BTC' },
  krwValue: { ko: '원화 환산', en: 'KRW Value', ja: 'KRW換算' },
  usdValue: { ko: '달러 환산', en: 'USD Value', ja: 'USD換算' },
  addresses: { ko: '주소 수', en: 'Addresses', ja: 'アドレス数' },
  chartHint: { ko: '주소를 2개 이상 추가하면 분포 차트가 표시됩니다', en: 'Add 2+ addresses to see distribution chart', ja: '2つ以上のアドレスを追加すると分布チャートが表示されます' },
  refreshAll: { ko: '전체 새로고침', en: 'Refresh All', ja: '全更新' },
  exportBtn: { ko: '내보내기', en: 'Export', ja: 'エクスポート' },
  importBtn: { ko: '가져오기', en: 'Import', ja: 'インポート' },
  clearAll: { ko: '전체 삭제', en: 'Clear All', ja: '全削除' },
};

const tx = (key: string) => i18n[key]?.[lang!] || i18n[key]?.en || key;
const learnLangPrefix = lang === 'en' ? 'en' : lang === 'ja' ? 'ja' : 'ko';
---

<Base
  title={titles[lang!] || titles.en}
  description={descriptions[lang!] || descriptions.en}
  lang={lang!}
>
  <Header sub="Portfolio" />

  <div class="learn-links" id="learn-links">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-noshrink" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    <span class="learn-label">{tx('learnMore')}</span>
    <a class="learn-chip" data-slug="bitcoin-wallet-address" href={`https://learn.txid.uk/${learnLangPrefix}/blog/bitcoin-wallet-address/`} target="_blank" rel="noopener">{tx('walletChip')}</a>
    <a class="learn-chip" data-slug="utxo-model" href={`https://learn.txid.uk/${learnLangPrefix}/blog/utxo-model/`} target="_blank" rel="noopener">{tx('utxoChip')}</a>
  </div>

  <main id="main">
    <div class="hero">
      <h1>BTC <span class="accent">Portfolio</span></h1>
      <p class="hero-sub">{tx('heroSub')}</p>
    </div>

    <div class="content">
      <AddressForm
        addrPlaceholder={tx('addrPlaceholder')}
        labelPlaceholder={tx('labelPlaceholder')}
        addBtnText={tx('addBtn')}
      />

      <PortfolioSummary
        totalBtcLabel={tx('totalBtc')}
        krwValueLabel={tx('krwValue')}
        usdValueLabel={tx('usdValue')}
        addressesLabel={tx('addresses')}
      />

      <DonutChart chartHint={tx('chartHint')} />

      <div id="addr-list" class="addr-list"></div>

      <div class="action-row">
        <button class="btn secondary" id="btn-refresh"><svg width="13" height="13" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> {tx('refreshAll')}</button>
        <button class="btn secondary" id="btn-export"><svg width="13" height="13" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg> {tx('exportBtn')}</button>
        <button class="btn secondary" id="btn-import"><svg width="13" height="13" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg> {tx('importBtn')}</button>
        <button class="btn danger" id="btn-clear"><svg width="13" height="13" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg> {tx('clearAll')}</button>
      </div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ pageLang: lang }}>
    window.__pageLang = pageLang;
  </script>
  <script src="/js/portfolio-i18n.js" is:inline></script>
  <script src="/js/portfolio-core.js" is:inline></script>
  <script src="/js/portfolio-ui.js" is:inline></script>
</Base>
